{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "FlowForge.Engine.Packages": "Debug"
    }
  },
  "Authentication": {
    "Provider": "BuiltIn"
  },
  "FlowForge": {
    "Packages": {
      "CacheDirectory": "./packages",
      "ManifestPath": "./packages/manifest.json",
      "RequireSignedPackages": false,
      "RequireUntrustedSourceConfirmation": false
    }
  }
}
