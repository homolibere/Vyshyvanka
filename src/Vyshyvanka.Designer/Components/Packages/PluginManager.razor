@namespace Vyshyvanka.Designer.Components
@* Main Plugin Manager component with tab navigation *@

<div class="modal-overlay @(IsOpen ? "open" : "")" @onclick="HandleOverlayClick">
    <div class="plugin-manager-modal" @onclick:stopPropagation="true">
        <div class="modal-header">
            <h2>Plugin Manager</h2>
            <button class="btn-close" @onclick="Close" disabled="@PluginState.IsLoading">×</button>
        </div>

        <div class="plugin-manager-tabs">
            <button class="tab @(IsInstalledTabActive ? "active" : "")"
                    @onclick="SelectInstalledTab">
                Installed
                @if (PluginState.InstalledPackages.Count > 0)
                {
                    <span class="tab-count">@PluginState.InstalledPackages.Count</span>
                }
            </button>
            <button class="tab @(IsBrowseTabActive ? "active" : "")"
                    @onclick="SelectBrowseTab">
                Browse
            </button>
            <button class="tab @(IsSourcesTabActive ? "active" : "")"
                    @onclick="SelectSourcesTab">
                Sources
                @if (PluginState.Sources.Count > 0)
                {
                    <span class="tab-count">@PluginState.Sources.Count</span>
                }
            </button>
        </div>

        <div class="plugin-manager-content">
            @if (IsInstalledTabActive)
            {
                <InstalledPackages OnNavigateToBrowse="NavigateToBrowse"
                                   OnShowDetails="ShowPackageDetails"/>
            }
            else if (IsBrowseTabActive)
            {
                <BrowsePackages OnShowDetails="ShowPackageDetails"/>
            }
            else if (IsSourcesTabActive)
            {
                <SourceManager OnAddSource="ShowAddSourceModal"
                               OnEditSource="ShowEditSourceModal"/>
            }
        </div>
    </div>
</div>

@* Package Details Modal *@
<PackageDetailsModal IsOpen="@_isPackageDetailsOpen"
                     PackageId="@_selectedPackageId"
                     OnClose="ClosePackageDetails"
                     OnInstalled="OnPackageInstalled"
                     OnUpdated="OnPackageUpdated"
                     OnUninstalled="OnPackageUninstalled"/>

@* Source Edit Modal *@
<SourceEditModal IsOpen="@_isSourceEditOpen"
                 Source="@_editingSource"
                 OnClose="CloseSourceEdit"
                 OnSaved="OnSourceSaved"/>