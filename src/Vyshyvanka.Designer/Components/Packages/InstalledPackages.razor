@namespace Vyshyvanka.Designer.Components
@* Installed packages tab content component *@

<div class="installed-packages">
    <div class="tab-toolbar">
        <button class="btn btn-secondary" @onclick="CheckForUpdatesAsync" disabled="@(PluginState.IsLoading || PluginState.IsCheckingForUpdates)">
            @if (PluginState.IsCheckingForUpdates)
            {
                <span>🔄 Checking...</span>
            }
            else
            {
                <span>🔄 Check for Updates</span>
            }
        </button>
        <label class="btn btn-secondary upload-btn" for="nupkg-upload">
            @if (_isUploading)
            {
                <span>⏳ Uploading...</span>
            }
            else
            {
                <span>📁 Upload .nupkg</span>
            }
        </label>
        <InputFile id="nupkg-upload"
                   accept=".nupkg"
                   OnChange="HandleFileUpload"
                   disabled="@_isUploading"
                   style="display:none" />
        @if (PluginState.AvailableUpdates.Count > 0)
        {
            <span class="update-count">@PluginState.AvailableUpdates.Count update(s) available</span>
        }
    </div>

    @if (PluginState.IsLoading && !PluginState.InstalledPackages.Any())
    {
        <div class="loading-state">
            <div class="loading-spinner"></div>
            <p>@(PluginState.StatusMessage ?? "Loading packages...")</p>
        </div>
    }
    else if (!PluginState.InstalledPackages.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">📦</div>
            <h4>No packages installed</h4>
            <p>Browse available packages to extend your workflow capabilities.</p>
            <button class="btn btn-primary" @onclick="GoToBrowse">
                Browse Packages
            </button>
        </div>
    }
    else
    {
        <div class="package-list">
            @foreach (var package in PluginState.InstalledPackages)
            {
                <PackageCard PackageId="@package.PackageId"
                             Title="@package.PackageId"
                             Version="@package.Version"
                             IsInstalled="true"
                             HasUpdate="@package.HasUpdate"
                             LatestVersion="@package.LatestVersion"
                             NodeCount="@package.NodeTypes.Count"
                             IsLoading="@PluginState.IsLoading"
                             IsUpdating="@PluginState.IsPackageBeingUpdated(package.PackageId)"
                             IsUninstalling="@PluginState.IsPackageBeingUninstalled(package.PackageId)"
                             OnClick="() => ShowDetailsAsync(package.PackageId)"
                             OnUpdate="() => UpdatePackageAsync(package.PackageId)"
                             OnUninstall="() => UninstallPackageAsync(package.PackageId)"/>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(PluginState.ErrorMessage))
    {
        <div class="error-message">
            <span>@PluginState.ErrorMessage</span>
            <button class="btn-retry" @onclick="RetryLoadPackagesAsync">Retry</button>
            <button class="btn-dismiss" @onclick="DismissError">×</button>
        </div>
    }
</div>

@* Confirmation dialog for uninstallation *@
<ConfirmDialog IsOpen="@_showUninstallConfirm"
               Title="Uninstall Package"
               Message="@_uninstallMessage"
               Icon="🗑️"
               ConfirmText="Uninstall"
               CancelText="Cancel"
               Variant="@_uninstallVariant"
               AffectedItems="@_affectedWorkflows"
               AffectedItemsLabel="@(_affectedWorkflows.Count > 0 ? "Affected workflows:" : null)"
               IsProcessing="@_isUninstalling"
               ProcessingText="Uninstalling..."
               OnConfirm="ConfirmUninstallAsync"
               OnCancel="CancelUninstall"/>