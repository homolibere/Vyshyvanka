@namespace Vyshyvanka.Designer.Components
<div class="canvas-container"
     @ref="_canvasContainer"
     @onmousedown="OnCanvasMouseDown"
     @onmousemove="OnCanvasMouseMove"
     @onmouseup="OnCanvasMouseUp"
     @onmouseleave="OnCanvasMouseUp"
     @onwheel="OnCanvasWheel"
     @ondrop="OnDrop"
     @ondragover="OnDragOver"
     @ondragover:preventDefault>

    <svg class="canvas-svg"
         width="100%"
         height="100%"
         viewBox="@GetViewBox()">

        <!-- Canvas background pattern -->
        <defs>
            @if (ThemeService.IsVyshyvankaPattern)
            {
                <pattern id="vyshyvanka-tile" width="80" height="80" patternUnits="userSpaceOnUse">
                    <!-- Central diamond (rhombus) -->
                    <rect x="38" y="30" width="4" height="4" fill="var(--grid-motif)" opacity="0.35"/>
                    <rect x="34" y="34" width="4" height="4" fill="var(--grid-motif)" opacity="0.35"/>
                    <rect x="42" y="34" width="4" height="4" fill="var(--grid-motif)" opacity="0.35"/>
                    <rect x="30" y="38" width="4" height="4" fill="var(--grid-motif)" opacity="0.35"/>
                    <rect x="46" y="38" width="4" height="4" fill="var(--grid-motif)" opacity="0.35"/>
                    <rect x="34" y="42" width="4" height="4" fill="var(--grid-motif)" opacity="0.35"/>
                    <rect x="42" y="42" width="4" height="4" fill="var(--grid-motif)" opacity="0.35"/>
                    <rect x="38" y="46" width="4" height="4" fill="var(--grid-motif)" opacity="0.35"/>

                    <!-- Cross-stitch X at center -->
                    <rect x="36" y="36" width="4" height="4" fill="var(--grid-accent)" opacity="0.25"/>
                    <rect x="40" y="36" width="4" height="4" fill="var(--grid-accent)" opacity="0.25"/>
                    <rect x="36" y="40" width="4" height="4" fill="var(--grid-accent)" opacity="0.25"/>
                    <rect x="40" y="40" width="4" height="4" fill="var(--grid-accent)" opacity="0.25"/>

                    <!-- Corner diamonds -->
                    <rect x="0" y="0" width="4" height="4" fill="var(--grid-motif)" opacity="0.2"/>
                    <rect x="76" y="0" width="4" height="4" fill="var(--grid-motif)" opacity="0.2"/>
                    <rect x="0" y="76" width="4" height="4" fill="var(--grid-motif)" opacity="0.2"/>
                    <rect x="76" y="76" width="4" height="4" fill="var(--grid-motif)" opacity="0.2"/>

                    <!-- Edge midpoints -->
                    <rect x="38" y="2" width="4" height="4" fill="var(--grid-motif)" opacity="0.15"/>
                    <rect x="2" y="38" width="4" height="4" fill="var(--grid-motif)" opacity="0.15"/>
                    <rect x="74" y="38" width="4" height="4" fill="var(--grid-motif)" opacity="0.15"/>
                    <rect x="38" y="74" width="4" height="4" fill="var(--grid-motif)" opacity="0.15"/>

                    <!-- Diagonal arms -->
                    <rect x="26" y="26" width="4" height="4" fill="var(--grid-motif)" opacity="0.18"/>
                    <rect x="50" y="26" width="4" height="4" fill="var(--grid-motif)" opacity="0.18"/>
                    <rect x="26" y="50" width="4" height="4" fill="var(--grid-motif)" opacity="0.18"/>
                    <rect x="50" y="50" width="4" height="4" fill="var(--grid-motif)" opacity="0.18"/>

                    <!-- Tiny dots -->
                    <rect x="18" y="18" width="2" height="2" fill="var(--grid-motif)" opacity="0.12"/>
                    <rect x="60" y="18" width="2" height="2" fill="var(--grid-motif)" opacity="0.12"/>
                    <rect x="18" y="60" width="2" height="2" fill="var(--grid-motif)" opacity="0.12"/>
                    <rect x="60" y="60" width="2" height="2" fill="var(--grid-motif)" opacity="0.12"/>

                    <!-- Stepping pixels -->
                    <rect x="22" y="30" width="2" height="2" fill="var(--grid-motif)" opacity="0.12"/>
                    <rect x="56" y="30" width="2" height="2" fill="var(--grid-motif)" opacity="0.12"/>
                    <rect x="22" y="48" width="2" height="2" fill="var(--grid-motif)" opacity="0.12"/>
                    <rect x="56" y="48" width="2" height="2" fill="var(--grid-motif)" opacity="0.12"/>
                    <rect x="30" y="22" width="2" height="2" fill="var(--grid-motif)" opacity="0.12"/>
                    <rect x="48" y="22" width="2" height="2" fill="var(--grid-motif)" opacity="0.12"/>
                    <rect x="30" y="56" width="2" height="2" fill="var(--grid-motif)" opacity="0.12"/>
                    <rect x="48" y="56" width="2" height="2" fill="var(--grid-motif)" opacity="0.12"/>
                </pattern>
            }
            else
            {
                <pattern id="dot-grid" width="20" height="20" patternUnits="userSpaceOnUse">
                    <circle cx="1" cy="1" r="1" fill="var(--grid-motif)" opacity="0.3"/>
                </pattern>
                <pattern id="dot-grid-large" width="100" height="100" patternUnits="userSpaceOnUse">
                    <rect width="100" height="100" fill="url(#dot-grid)"/>
                    <circle cx="0" cy="0" r="2" fill="var(--grid-motif)" opacity="0.2"/>
                </pattern>
            }
        </defs>

        <!-- Background -->
        <rect x="-10000" y="-10000" width="20000" height="20000" fill="var(--bg-canvas)"/>
        <rect x="-10000" y="-10000" width="20000" height="20000"
              fill="url(#@(ThemeService.IsVyshyvankaPattern ? "vyshyvanka-tile" : "dot-grid-large"))"/>

        <!-- Connections layer -->
        <g class="connections-layer">
            @foreach (var connection in StateService.Workflow.Connections)
            {
                var coords = GetConnectionCoordinates(connection);
                <ConnectionLine
                    Connection="@connection"
                    StartX="@coords.StartX"
                    StartY="@coords.StartY"
                    EndX="@coords.EndX"
                    EndY="@coords.EndY"
                    IsSelected="@(StateService.SelectedConnection == connection)"
                    OnSelect="@(() => StateService.SelectConnection(connection))"
                    OnDelete="@(() => StateService.RemoveConnection(connection))"/>
            }

            @if (StateService.PendingConnection is not null)
            {
                var pending = StateService.PendingConnection;
                var startCoords = GetPortPosition(pending.SourceNodeId, pending.SourcePort, isOutput: true);
                <path class="pending-connection"
                      d="@GetBezierPath(startCoords.X, startCoords.Y, pending.CurrentX, pending.CurrentY)"/>
            }
        </g>

        <!-- Nodes layer -->
        <g class="nodes-layer">
            @foreach (var node in StateService.Workflow.Nodes)
            {
                <CanvasNodeComponent
                    Node="@node"
                    Definition="@StateService.GetNodeDefinition(node.Type)"
                    IsSelected="@(StateService.SelectedNodeId == node.Id)"
                    OnSelect="@(() => StateService.SelectNode(node.Id))"
                    OnStartDrag="@((e) => StartNodeDrag(node.Id, e))"
                    OnStartConnection="@((port) => StartConnection(node.Id, port))"
                    OnEndConnection="@((port) => EndConnection(node.Id, port))"
                    OnMove="@((pos) => StateService.MoveNode(node.Id, pos.X, pos.Y))"
                    OnDelete="@(() => StateService.RemoveNode(node.Id))"
                    OnDoubleClick="@(() => HandleNodeDoubleClick(node.Id))"/>
            }
        </g>
    </svg>
</div>