@namespace Vyshyvanka.Designer.Components

<div class="property-editor json-editor">
    <label class="property-label">
        @Property.DisplayName
        @if (Property.IsRequired)
        {
            <span class="required-indicator">*</span>
        }
        <span class="type-badge">@GetTypeBadge()</span>
    </label>
    
    <textarea class="property-textarea @(HasValidationError ? "has-error" : "")"
              placeholder="@GetPlaceholder()"
              @bind="_jsonText"
              @bind:event="oninput"
              @onblur="OnBlur"></textarea>
    
    @if (!string.IsNullOrEmpty(Property.Description))
    {
        <div class="property-description">@Property.Description</div>
    }
    
    @if (HasValidationError)
    {
        <div class="validation-error">@ValidationMessage</div>
    }
</div>
