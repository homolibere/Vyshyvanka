@namespace Vyshyvanka.Designer.Components

<div class="modal-overlay @(IsOpen ? "open" : "")" @onclick="HandleOverlayClick">
    <div class="credential-manager-modal" @onclick:stopPropagation="true">
        <div class="modal-header">
            <h2>🔑 Credentials</h2>
            <button class="btn-close" @onclick="Close" disabled="@_isSaving">×</button>
        </div>

        <div class="credential-manager-content">
            @if (_isLoading)
            {
                <div class="loading-state">Loading credentials…</div>
            }
            else
            {
                <div class="credential-toolbar">
                    <span class="credential-count">@_credentials.Count credential(s)</span>
                    <button class="btn-add" @onclick="ShowCreateForm" disabled="@_showCreateForm">
                        + New Credential
                    </button>
                </div>

                @if (_showCreateForm)
                {
                    <div class="credential-form">
                        <div class="form-title">Create Credential</div>
                        <div class="form-field">
                            <label class="field-label">Name</label>
                            <input class="form-input" placeholder="e.g. My GitLab Token" @bind="_formName" />
                        </div>
                        <div class="form-field">
                            <label class="field-label">Type</label>
                            <select class="form-input" @bind="_formType">
                                @foreach (var t in Enum.GetValues<Vyshyvanka.Core.Enums.CredentialType>())
                                {
                                    <option value="@t">@t</option>
                                }
                            </select>
                        </div>
                        @foreach (var field in GetFieldsForType(_formType))
                        {
                            <div class="form-field">
                                <label class="field-label">@field.Label</label>
                                <input class="form-input"
                                       type="@(field.IsSecret ? "password" : "text")"
                                       placeholder="@field.Label"
                                       value="@GetFieldValue(field.Key)"
                                       @onchange="@(e => SetFieldValue(field.Key, e.Value?.ToString() ?? ""))" />
                            </div>
                        }
                        <div class="form-actions">
                            <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                            <button class="btn btn-primary" @onclick="HandleCreate" disabled="@_isSaving">
                                @(_isSaving ? "Creating…" : "Create")
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(_formError))
                        {
                            <p class="form-error">@_formError</p>
                        }
                    </div>
                }

                <div class="credential-list">
                    @if (_credentials.Count == 0 && !_showCreateForm)
                    {
                        <div class="empty-state">
                            <span class="empty-icon">🔑</span>
                            <p>No credentials yet</p>
                            <p class="empty-hint">Credentials store authentication data for nodes that connect to external services.</p>
                            <button class="btn btn-primary" @onclick="ShowCreateForm">Create your first credential</button>
                        </div>
                    }
                    else
                    {
                        @foreach (var cred in _credentials)
                        {
                            <div class="credential-item @(_editingCredentialId == cred.Id ? "editing" : "")">
                                <div class="credential-info">
                                    <span class="credential-type-icon">@GetTypeIcon(cred.Type)</span>
                                    <div class="credential-details">
                                        <span class="credential-name">@cred.Name</span>
                                        <span class="credential-meta">@cred.Type · Updated @cred.UpdatedAt.ToString("MMM d, yyyy")</span>
                                    </div>
                                </div>
                                <div class="credential-actions">
                                    @if (_editingCredentialId != cred.Id)
                                    {
                                        <button class="btn-icon" title="Edit" @onclick="() => ShowEditForm(cred)">✏️</button>
                                    }
                                    <button class="btn-icon btn-danger" title="Delete" @onclick="() => RequestDelete(cred.Id)">🗑️</button>
                                </div>
                            </div>

                            @if (_editingCredentialId == cred.Id && _showEditForm)
                            {
                                <div class="credential-inline-form">
                                    <div class="form-field">
                                        <label class="field-label">Name</label>
                                        <input class="form-input" placeholder="Credential name" @bind="_formName" />
                                    </div>
                                    <div class="form-hint">Leave fields blank to keep existing values.</div>
                                    @foreach (var field in GetFieldsForType(_formType))
                                    {
                                        <div class="form-field">
                                            <label class="field-label">
                                                @field.Label
                                                @if (IsFieldStored(field.Key))
                                                {
                                                    <span class="stored-badge">✓ stored</span>
                                                }
                                            </label>
                                            <input class="form-input @(IsFieldStored(field.Key) ? "has-stored-value" : "")"
                                                   type="@(field.IsSecret ? "password" : "text")"
                                                   placeholder="@GetEditPlaceholder(field)"
                                                   value="@GetFieldValue(field.Key)"
                                                   @onchange="@(e => SetFieldValue(field.Key, e.Value?.ToString() ?? ""))" />
                                        </div>
                                    }
                                    <div class="form-actions">
                                        <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                                        <button class="btn btn-primary" @onclick="HandleUpdate" disabled="@_isSaving">
                                            @(_isSaving ? "Saving…" : "Save Changes")
                                        </button>
                                    </div>
                                    @if (!string.IsNullOrEmpty(_formError))
                                    {
                                        <p class="form-error">@_formError</p>
                                    }
                                </div>
                            }

                            @if (_confirmDeleteId == cred.Id)
                            {
                                <div class="delete-confirm">
                                    <span>Delete "<strong>@cred.Name</strong>"? This cannot be undone.</span>
                                    <div class="delete-confirm-actions">
                                        <button class="btn btn-secondary btn-sm" @onclick="CancelDelete">Cancel</button>
                                        <button class="btn btn-danger-solid btn-sm" @onclick="ConfirmDelete">Delete</button>
                                    </div>
                                </div>
                            }
                        }
                    }
                </div>
            }
        </div>
    </div>
</div>
