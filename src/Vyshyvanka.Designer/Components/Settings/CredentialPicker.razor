@namespace Vyshyvanka.Designer.Components

<div class="credential-picker">
    <label class="credential-label">Credential</label>

    <div class="credential-select-row">
        <select class="credential-select"
                value="@_selectedId"
                @onchange="HandleSelectionChanged">
            <option value="">— None —</option>
            @foreach (var cred in _credentials)
            {
                <option value="@cred.Id">@cred.Name (@cred.Type)</option>
            }
        </select>
        <button class="btn-add-credential" title="Create new credential" @onclick="ToggleCreateForm">+</button>
    </div>

    @if (_showCreateForm)
    {
        <div class="credential-create-form">
            <input class="form-input" placeholder="Credential name" @bind="_newName" />

            <select class="form-input" @bind="_newType">
                @foreach (var t in Enum.GetValues<Vyshyvanka.Core.Enums.CredentialType>())
                {
                    <option value="@t">@t</option>
                }
            </select>

            @foreach (var field in GetFieldsForType(_newType))
            {
                <input class="form-input"
                       type="@(field.IsSecret ? "password" : "text")"
                       placeholder="@field.Label"
                       value="@GetFieldValue(field.Key)"
                       @onchange="@(e => SetFieldValue(field.Key, e.Value?.ToString() ?? ""))" />
            }

            <div class="credential-create-actions">
                <button class="btn btn-sm btn-secondary" @onclick="ToggleCreateForm">Cancel</button>
                <button class="btn btn-sm btn-primary" @onclick="HandleCreate" disabled="@_isSaving">
                    @(_isSaving ? "Saving…" : "Create")
                </button>
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="credential-error">@_error</p>
            }
        </div>
    }
</div>
