@namespace Vyshyvanka.Designer.Components
@* Toast notification component *@

<div class="toast @GetTypeClass() @(_isVisible ? "visible" : "hiding")" role="alert">
    <div class="toast-icon">@GetIcon()</div>
    <div class="toast-content">
        @if (!string.IsNullOrEmpty(Title))
        {
            <div class="toast-title">@Title</div>
        }
        <div class="toast-message">@Message</div>
    </div>
    <div class="toast-actions">
        <button class="toast-copy @(_copied ? "copied" : "")" @onclick="CopyToClipboardAsync" aria-label="Copy message" title="Copy to clipboard">
            @(_copied ? "✓" : "📋")
        </button>
        <button class="toast-close" @onclick="Dismiss" aria-label="Close">×</button>
    </div>
</div>