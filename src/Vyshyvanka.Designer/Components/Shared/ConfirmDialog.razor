@namespace Vyshyvanka.Designer.Components
@* Reusable confirmation dialog component *@

<div class="modal-overlay @(IsOpen ? "open" : "")" @onclick="HandleOverlayClick">
    <div class="modal-content confirm-dialog" @onclick:stopPropagation="true">
        <div class="modal-header @GetHeaderClass()">
            @if (!string.IsNullOrEmpty(Icon))
            {
                <span class="dialog-icon">@Icon</span>
            }
            <h3>@Title</h3>
            <button class="btn-close" @onclick="HandleCancel" disabled="@IsProcessing">×</button>
        </div>

        <div class="modal-body">
            @if (!string.IsNullOrEmpty(Message))
            {
                <p class="dialog-message">@Message</p>
            }

            @if (AffectedItems.Count > 0)
            {
                <div class="affected-items-section">
                    @if (!string.IsNullOrEmpty(AffectedItemsLabel))
                    {
                        <span class="affected-items-label">@AffectedItemsLabel</span>
                    }
                    <ul class="affected-items-list">
                        @foreach (var item in AffectedItems)
                        {
                            <li>@item</li>
                        }
                    </ul>
                </div>
            }

            @if (ChildContent is not null)
            {
                @ChildContent
            }
        </div>

        <div class="modal-footer">
            <button class="btn btn-secondary" @onclick="HandleCancel" disabled="@IsProcessing">
                @CancelText
            </button>
            <button class="btn @GetConfirmButtonClass()" @onclick="HandleConfirm" disabled="@IsProcessing">
                @if (IsProcessing)
                {
                    <span class="processing-indicator">@ProcessingText</span>
                }
                else
                {
                    <span>@ConfirmText</span>
                }
            </button>
        </div>
    </div>
</div>