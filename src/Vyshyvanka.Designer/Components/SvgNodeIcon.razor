@namespace Vyshyvanka.Designer.Components

@if (IsUrl(Icon))
{
    <image href="@Icon" x="@X" y="@(Y - 14)" width="16" height="16"/>
}
else if (IsFontAwesome(Icon))
{
    <foreignObject x="@(X - 2)" y="@(Y - 16)" width="20" height="20">
        <i class="@Icon" style="font-size: 14px; color: white;" xmlns="http://www.w3.org/1999/xhtml"></i>
    </foreignObject>
}
else
{
    @((MarkupString)$"<text class=\"node-icon\" x=\"{X}\" y=\"{Y}\">{(string.IsNullOrEmpty(Icon) ? DefaultIcon : Icon)}</text>")
}


