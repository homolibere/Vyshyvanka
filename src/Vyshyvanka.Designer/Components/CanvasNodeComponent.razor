<g class="canvas-node @(IsSelected ? "selected" : "") @GetExecutionStatusClass()"
   transform="translate(@Node.Position.X, @Node.Position.Y)"
   @onclick="OnSelect"
   @onclick:stopPropagation
   @ondblclick="OnNodeDoubleClick"
   @ondblclick:stopPropagation
   @onmousedown="OnMouseDown"
   @onmousedown:stopPropagation>

    <!-- Node background -->
    <rect class="node-bg @GetCategoryClass()"
          width="@NodeWidth"
          height="@NodeHeight"
          rx="8"/>

    <!-- Execution status indicator -->
    @{
        var execState = StateService.GetNodeExecutionState(Node.Id);
    }
    @if (execState is not null)
    {
        <rect class="execution-indicator @GetExecutionIndicatorClass(execState.Status)"
              x="-3"
              y="-3"
              width="@(NodeWidth + 6)"
              height="@(NodeHeight + 6)"
              rx="10"
              fill="none"
              stroke-width="3"/>
    }

    <!-- Node header -->
    <rect class="node-header @GetCategoryClass()"
          width="@NodeWidth"
          height="28"
          rx="8"/>
    <rect class="node-header-bottom"
          y="20"
          width="@NodeWidth"
          height="8"/>

    <!-- Node icon and title -->
    <SvgNodeIcon Icon="@Definition?.Icon" X="12" Y="20"/>
    <text class="node-title" x="36" y="19">@Node.Name</text>

    <!-- Execution status badge -->
    @if (execState is not null)
    {
        <g class="execution-badge" transform="translate(@(NodeWidth - 24), -8)">
            <circle r="10" fill="@GetStatusBadgeColor(execState.Status)"/>
            <text x="0" y="4" text-anchor="middle" fill="white" font-size="10">@GetStatusBadgeIcon(execState.Status)</text>
        </g>
    }

    <!-- Delete button (shown when selected and not executing) -->
    @if (IsSelected && execState is null)
    {
        <g class="delete-btn" transform="translate(@(NodeWidth - 20), 4)" @onclick="OnDeleteClick" @onclick:stopPropagation>
            <circle r="8" fill="#ef5350"/>
            <text x="0" y="4" text-anchor="middle" fill="white" font-size="12">×</text>
        </g>
    }

    <!-- Execution duration (shown when completed) -->
    @if (execState?.DurationMs is not null)
    {
        <g class="execution-duration-group">
            <text class="execution-duration" x="@(NodeWidth / 2)" y="@(NodeHeight + 14)" text-anchor="middle">@FormatDuration(execState.DurationMs.Value)</text>
        </g>
    }

    <!-- Input ports -->
    @if (Definition?.Inputs is not null)
    {
        var inputCount = Definition.Inputs.Count;
        var startY = (NodeHeight - (inputCount - 1) * PortSpacing) / 2;

        @for (var i = 0; i < inputCount; i++)
        {
            var port = Definition.Inputs[i];
            var portY = startY + i * PortSpacing;
            <g class="port input-port"
               transform="translate(0, @portY)"
               @onmouseup="() => OnPortMouseUp(port.Name)"
               @onmouseup:stopPropagation>
                <circle r="6" class="port-circle @GetPortTypeClass(port.Type)"/>
                <text class="port-label" x="12" y="4">@port.DisplayName</text>
            </g>
        }
    }

    <!-- Output ports -->
    @if (Definition?.Outputs is not null)
    {
        var outputCount = Definition.Outputs.Count;
        var startY = (NodeHeight - (outputCount - 1) * PortSpacing) / 2;

        @for (var i = 0; i < outputCount; i++)
        {
            var port = Definition.Outputs[i];
            var portY = startY + i * PortSpacing;
            <g class="port output-port"
               transform="translate(@NodeWidth, @portY)"
               @onmousedown="() => OnPortMouseDown(port.Name)"
               @onmousedown:stopPropagation>
                <circle r="6" class="port-circle @GetPortTypeClass(port.Type)"/>
                <text class="port-label" x="-12" y="4" text-anchor="end">@port.DisplayName</text>
            </g>
        }
    }
</g>

