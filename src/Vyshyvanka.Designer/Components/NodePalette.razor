<div class="palette-container">
    <div class="palette-header">
        <h3>Nodes</h3>
    </div>

    <div class="palette-search">
        <input type="text" placeholder="Search nodes..." @bind="searchText" @bind:event="oninput"/>
    </div>

    @foreach (var category in GetGroupedNodes())
    {
        <div class="palette-category">
            <div class="category-header" @onclick="() => ToggleCategory(category.Key)">
                <span class="category-icon">@GetCategoryIcon(category.Key)</span>
                <span class="category-name">@category.Key</span>
                <span class="category-toggle">@(expandedCategories.Contains(category.Key) ? "▼" : "▶")</span>
            </div>

            @if (expandedCategories.Contains(category.Key))
            {
                <div class="category-nodes">
                    @foreach (var node in category)
                    {
                        <div class="palette-node @(node.IsPluginNode ? "plugin-node" : "")"
                             draggable="true"
                             @ondragstart="() => OnDragStart(node)"
                             @ondragend="OnDragEnd"
                             title="@GetNodeTooltip(node)">
                            <span class="node-icon">
                                <NodeIcon Icon="@node.Icon"/>
                            </span>
                            <div class="node-info">
                                <span class="node-name">
                                    @node.Name
                                    @if (node.IsPluginNode)
                                    {
                                        <span class="plugin-badge" title="Plugin: @node.SourcePackage">🔌</span>
                                    }
                                </span>
                                <span class="node-description">@node.Description</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

