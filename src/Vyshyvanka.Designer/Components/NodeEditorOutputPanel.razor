@namespace Vyshyvanka.Designer.Components

<div class="node-editor-panel output-panel">
    <div class="panel-header">
        <span class="panel-title">Output</span>
    </div>
    
    <div class="panel-content">
        @if (HasOutputData)
        {
            <pre class="json-viewer">@FormattedJson</pre>
        }
        else
        {
            <div class="placeholder">
                <span class="placeholder-icon">📤</span>
                <span class="placeholder-text">No output data available</span>
                <span class="placeholder-hint">Execute the workflow to see output data</span>
            </div>
        }
    </div>
</div>
