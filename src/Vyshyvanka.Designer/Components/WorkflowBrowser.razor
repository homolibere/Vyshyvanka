<div class="modal-overlay @(IsOpen ? "open" : "")" @onclick="HandleOverlayClick">
    <div class="workflow-browser-modal" @onclick:stopPropagation="true">
        <div class="modal-header">
            <h2>Open Workflow</h2>
            <button class="btn-close" @onclick="Close" disabled="@_isLoading">×</button>
        </div>

        <div class="browser-toolbar">
            <input type="text"
                   class="search-input"
                   placeholder="Search workflows..."
                   @bind="_searchQuery"
                   @bind:event="oninput"
                   @onkeyup="OnSearchKeyUp"/>
            <button class="btn-new" @onclick="CreateNewWorkflow">
                + New Workflow
            </button>
        </div>

        <div class="workflow-list">
            @if (_isLoading)
            {
                <div class="loading-state">
                    <span class="spinner"></span>
                    <span>Loading workflows...</span>
                </div>
            }
            else if (_error is not null)
            {
                <div class="error-state">
                    <span>⚠️ @_error</span>
                    <button class="btn-retry" @onclick="LoadWorkflowsAsync">Retry</button>
                </div>
            }
            else if (!FilteredWorkflows.Any())
            {
                <div class="empty-state">
                    @if (string.IsNullOrWhiteSpace(_searchQuery))
                    {
                        <span>No workflows yet. Create your first one!</span>
                    }
                    else
                    {
                        <span>No workflows match "@_searchQuery"</span>
                    }
                </div>
            }
            else
            {
                @foreach (var workflow in FilteredWorkflows)
                {
                    <div class="workflow-item @(workflow.Id == CurrentWorkflowId ? "current" : "")"
                         @onclick="() => SelectWorkflow(workflow.Id)">
                        <div class="workflow-info">
                            <div class="workflow-name">
                                <span class="status-dot @(workflow.IsActive ? "active" : "inactive")"></span>
                                @workflow.Name
                                @if (workflow.Id == CurrentWorkflowId)
                                {
                                    <span class="current-badge">Current</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(workflow.Description))
                            {
                                <div class="workflow-description">@workflow.Description</div>
                            }
                            <div class="workflow-meta">
                                <span>v@(workflow.Version)</span>
                                <span>•</span>
                                <span>@FormatDate(workflow.UpdatedAt)</span>
                            </div>
                        </div>
                        <div class="workflow-actions">
                            <button class="btn-open" title="Open workflow">→</button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

