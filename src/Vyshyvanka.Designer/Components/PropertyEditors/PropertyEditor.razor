@namespace Vyshyvanka.Designer.Components

@switch (GetEditorType())
{
    case EditorType.WorkflowSelect:
        <WorkflowSelectPropertyEditor Property="@Property"
                                      Value="@Value"
                                      ValueChanged="@OnValueChanged"
                                      ShowValidationError="@ShowValidationError"/>
        break;

    case EditorType.Select:
        <SelectPropertyEditor Property="@Property"
                              Value="@Value"
                              ValueChanged="@OnValueChanged"
                              ShowValidationError="@ShowValidationError"/>
        break;

    case EditorType.Number:
        <NumberPropertyEditor Property="@Property"
                              Value="@Value"
                              ValueChanged="@OnValueChanged"
                              ShowValidationError="@ShowValidationError"/>
        break;

    case EditorType.Boolean:
        <BooleanPropertyEditor Property="@Property"
                               Value="@Value"
                               ValueChanged="@OnValueChanged"
                               ShowValidationError="@ShowValidationError"/>
        break;

    case EditorType.Json:
        <JsonPropertyEditor Property="@Property"
                            Value="@Value"
                            ValueChanged="@OnValueChanged"
                            ShowValidationError="@ShowValidationError"/>
        break;

    case EditorType.Code:
        <CodePropertyEditor Property="@Property"
                            Value="@Value"
                            ValueChanged="@OnValueChanged"
                            ShowValidationError="@ShowValidationError"/>
        break;

    case EditorType.String:
    default:
        <StringPropertyEditor Property="@Property"
                              Value="@Value"
                              ValueChanged="@OnValueChanged"
                              ShowValidationError="@ShowValidationError"/>
        break;
}
