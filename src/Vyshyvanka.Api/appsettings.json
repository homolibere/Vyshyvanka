{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Authentication": {
    "Provider": "BuiltIn"
  },
  "CredentialStorage": {
    "Provider": "BuiltIn"
  },
  "Vyshyvanka": {
    "Packages": {
      "CacheDirectory": "./packages",
      "ManifestPath": "./packages/manifest.json",
      "RequireSignedPackages": false,
      "AllowedPackages": [],
      "BlockedPackages": [],
      "RequireUntrustedSourceConfirmation": true
    }
  }
}
