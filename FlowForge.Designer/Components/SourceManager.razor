@* Source manager tab content component *@

<div class="source-manager">
    <div class="tab-toolbar">
        <button class="btn btn-primary" @onclick="AddSourceAsync" disabled="@PluginState.IsLoading">
            ➕ Add Source
        </button>
    </div>

    @if (PluginState.IsLoading && !PluginState.Sources.Any())
    {
        <div class="loading-state">
            <div class="loading-spinner"></div>
            <p>@(PluginState.StatusMessage ?? "Loading sources...")</p>
        </div>
    }
    else if (!PluginState.Sources.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">🔗</div>
            <h4>No package sources configured</h4>
            <p>Add a package source to browse and install packages.</p>
            <button class="btn btn-primary" @onclick="AddSourceAsync">
                Add Source
            </button>
        </div>
    }
    else
    {
        <div class="source-list">
            @foreach (var source in PluginState.Sources)
            {
                <div class="source-item @(!source.IsEnabled ? "disabled" : "")">
                    <div class="source-info">
                        <div class="source-header">
                            <span class="source-name">@source.Name</span>
                            @if (source.IsTrusted)
                            {
                                <span class="trusted-badge" title="Trusted source">✓ Trusted</span>
                            }
                            @if (!source.IsEnabled)
                            {
                                <span class="disabled-badge" title="Source is disabled">Disabled</span>
                            }
                            @if (source.HasCredentials)
                            {
                                <span class="credentials-badge" title="Has credentials configured">🔑</span>
                            }
                        </div>
                        <span class="source-url">@source.Url</span>
                        @if (_testResults.TryGetValue(source.Name, out var testResult))
                        {
                            <div class="test-result @(testResult.Success ? "success" : "failure")">
                                @if (testResult.Success)
                                {
                                    <span class="test-status">✓ Connected (@(testResult.ResponseTimeMs)ms)</span>
                                }
                                else
                                {
                                    <span class="test-status">✗ @testResult.ErrorMessage</span>
                                }
                            </div>
                        }
                    </div>
                    <div class="source-actions">
                        <button class="btn btn-sm btn-secondary"
                                @onclick="() => TestSourceAsync(source.Name)"
                                @onclick:stopPropagation="true"
                                disabled="@(PluginState.IsLoading || PluginState.IsSourceBeingTested(source.Name))">
                            @if (PluginState.IsSourceBeingTested(source.Name))
                            {
                                <span>Testing...</span>
                            }
                            else
                            {
                                <span>Test</span>
                            }
                        </button>
                        <button class="btn btn-sm btn-secondary"
                                @onclick="() => EditSourceAsync(source)"
                                @onclick:stopPropagation="true"
                                disabled="@PluginState.IsLoading">
                            Edit
                        </button>
                        <button class="btn btn-sm btn-danger"
                                @onclick="() => RemoveSourceAsync(source.Name)"
                                @onclick:stopPropagation="true"
                                disabled="@PluginState.IsLoading">
                            Remove
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(PluginState.ErrorMessage))
    {
        <div class="error-message">
            <span>@PluginState.ErrorMessage</span>
            <button class="btn-retry" @onclick="RetryLoadSourcesAsync">Retry</button>
            <button class="btn-dismiss" @onclick="DismissError">×</button>
        </div>
    }

    @if (!string.IsNullOrEmpty(PluginState.StatusMessage) && !PluginState.IsLoading)
    {
        <div class="status-message">
            <span>@PluginState.StatusMessage</span>
            <button class="btn-dismiss" @onclick="DismissStatus">×</button>
        </div>
    }
</div>

