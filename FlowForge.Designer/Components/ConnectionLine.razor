<g class="connection @(IsSelected ? "selected" : "")">

    <!-- Invisible wider path for easier clicking -->
    <path class="connection-hitarea"
          d="@GetBezierPath()"
          @onclick="OnSelectClick"
          @onclick:stopPropagation/>

    <!-- Visible connection line -->
    <path class="connection-line"
          d="@GetBezierPath()"
          @onclick="OnSelectClick"
          @onclick:stopPropagation/>

    <!-- Arrow at the end -->
    <polygon class="connection-arrow"
             points="@GetArrowPoints()"
             transform="@GetArrowTransform()"
             @onclick="OnSelectClick"
             @onclick:stopPropagation/>

    <!-- Delete button (shown when selected) -->
    @if (IsSelected)
    {
        var midX = (StartX + EndX) / 2;
        var midY = (StartY + EndY) / 2;
        <g class="delete-btn"
           transform="translate(@midX, @midY)"
           style="pointer-events: all;"
           @onmousedown:stopPropagation
           @onclick="OnDeleteClick"
           @onclick:preventDefault
           @onclick:stopPropagation>
            <circle r="10" fill="#ef5350"/>
            <text x="0" y="4" text-anchor="middle" fill="white" font-size="14" style="pointer-events: none;">×</text>
        </g>
    }
</g>

@code {
    [Parameter, EditorRequired] public Connection Connection { get; set; } = null!;

    [Parameter] public double StartX { get; set; }

    [Parameter] public double StartY { get; set; }

    [Parameter] public double EndX { get; set; }

    [Parameter] public double EndY { get; set; }

    [Parameter] public bool IsSelected { get; set; }

    [Parameter] public EventCallback OnSelect { get; set; }

    [Parameter] public EventCallback OnDelete { get; set; }

    private string GetBezierPath()
    {
        var dx = Math.Abs(EndX - StartX) * 0.5;
        var cp1x = StartX + dx;
        var cp2x = EndX - dx;
        return $"M {StartX} {StartY} C {cp1x} {StartY}, {cp2x} {EndY}, {EndX} {EndY}";
    }

    private static string GetArrowPoints() => "-6,-4 0,0 -6,4";

    private string GetArrowTransform()
    {
        var angle = Math.Atan2(EndY - StartY, EndX - StartX) * 180 / Math.PI;
        return $"translate({EndX}, {EndY}) rotate({angle})";
    }

    private async Task OnSelectClick()
    {
        await OnSelect.InvokeAsync();
    }

    private async Task OnDeleteClick()
    {
        await OnDelete.InvokeAsync();
    }

}
