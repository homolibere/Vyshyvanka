@* Package card component for displaying package information *@<div class="package-card @(IsInstalled ? "installed" : "")" @onclick="HandleClick">
    <div class="package-icon">
        @if (!string.IsNullOrEmpty(IconUrl))
        {
            <img src="@IconUrl" alt="@Title"/>
        }
        else
        {
            <span class="default-icon">📦</span>
        }
    </div>

    <div class="package-info">
        <div class="package-header">
            <h4 class="package-title">@(Title ?? PackageId)</h4>
            <span class="package-version">v@(Version)</span>
            @if (HasUpdate)
            {
                <span class="update-badge" title="Update available to @LatestVersion">⬆</span>
            }
        </div>

        @if (!string.IsNullOrEmpty(Description))
        {
            <p class="package-description">@Description</p>
        }

        <div class="package-meta">
            @if (!string.IsNullOrEmpty(Authors))
            {
                <span class="meta-item">👤 @Authors</span>
            }
            @if (DownloadCount > 0)
            {
                <span class="meta-item">⬇ @FormatDownloads(DownloadCount)</span>
            }
            @if (NodeCount > 0)
            {
                <span class="meta-item">🔲 @NodeCount nodes</span>
            }
            @if (IsInstalled && !string.IsNullOrEmpty(InstalledVersion))
            {
                <span class="meta-item installed-version">✓ Installed v@(InstalledVersion)</span>
            }
        </div>
    </div>

    <div class="package-actions" @onclick:stopPropagation>
        @if (IsInstalled)
        {
            @if (HasUpdate)
            {
                <button class="btn btn-primary" @onclick="HandleUpdate" disabled="@(IsLoading || IsOperationInProgress)">
                    @if (IsUpdating)
                    {
                        <span class="btn-loading">Updating...</span>
                    }
                    else
                    {
                        <span>Update</span>
                    }
                </button>
            }

            <button class="btn btn-danger" @onclick="HandleUninstall" disabled="@(IsLoading || IsOperationInProgress)">
                @if (IsUninstalling)
                {
                    <span class="btn-loading">Uninstalling...</span>
                }
                else
                {
                    <span>Uninstall</span>
                }
            </button>
        }
        else
        {
            <button class="btn btn-primary" @onclick="HandleInstall" disabled="@(IsLoading || IsOperationInProgress)">
                @if (IsInstalling)
                {
                    <span class="btn-loading">Installing...</span>
                }
                else
                {
                    <span>Install</span>
                }
            </button>
        }
    </div>
</div>

