@page "/designer"
@page "/designer/{WorkflowId:guid}"
@layout DesignerLayout

<PageTitle>@(StateService.Workflow.Name) - FlowForge Designer</PageTitle>

<div class="designer-container">
    <aside class="node-palette @(_isPaletteCollapsed ? "collapsed" : "")">
        <div class="panel-toggle" @onclick="TogglePalette" title="@(_isPaletteCollapsed ? "Show Nodes" : "Hide Nodes")">
            <span class="toggle-icon">@(_isPaletteCollapsed ? "▶" : "◀")</span>
            @if (_isPaletteCollapsed)
            {
                <span class="toggle-label-vertical">Nodes</span>
            }
        </div>
        @if (!_isPaletteCollapsed)
        {
            <NodePalette/>
        }
    </aside>

    <div class="canvas-area">
        <div class="canvas-toolbar">
            <button class="toolbar-btn" @onclick="OpenWorkflowBrowser" title="Open Workflow">
                📂 Open
            </button>
            <span class="toolbar-separator"></span>
            <button class="toolbar-btn" @onclick="StateService.Undo" disabled="@(!StateService.CanUndo)" title="Undo">
                ↶
            </button>
            <button class="toolbar-btn" @onclick="StateService.Redo" disabled="@(!StateService.CanRedo)" title="Redo">
                ↷
            </button>
            <span class="toolbar-separator"></span>
            <button class="toolbar-btn" @onclick="ZoomIn" title="Zoom In">+</button>
            <span class="zoom-level">@((StateService.CanvasState.Zoom * 100).ToString("0"))%</span>
            <button class="toolbar-btn" @onclick="ZoomOut" title="Zoom Out">−</button>
            <button class="toolbar-btn" @onclick="StateService.ResetView" title="Reset View">⟲</button>
            <span class="toolbar-separator"></span>
            @if (StateService.IsDirty)
            {
                <span class="dirty-indicator" title="Unsaved changes">●</span>
            }
            <button class="toolbar-btn primary" @onclick="SaveWorkflow" disabled="@(!StateService.ValidationResult.IsValid)" title="@GetSaveButtonTitle()">
                💾 Save
            </button>
            <button class="toolbar-btn @(StateService.Workflow.IsActive ? "active" : "")" @onclick="ToggleWorkflowActive" title="@(StateService.Workflow.IsActive ? "Workflow is active (click to deactivate)" : "Workflow is inactive (click to activate)")">
                @(StateService.Workflow.IsActive ? "🟢 Active" : "⚪ Inactive")
            </button>
            <button class="toolbar-btn" @onclick="ExecuteWorkflow" disabled="@(!StateService.ValidationResult.IsValid || StateService.IsExecutionActive || !StateService.Workflow.IsActive)" title="@GetRunButtonTitle()">
                ▶ Run
            </button>
            @if (StateService.IsExecutionActive)
            {
                <button class="toolbar-btn" @onclick="StopExecution" title="Stop Execution">
                    ⏹ Stop
                </button>
            }
            <span class="toolbar-separator"></span>
            <button class="toolbar-btn" @onclick="OpenPluginManager" title="Plugin Manager">
                📦 Plugins
            </button>
            <button class="toolbar-btn" @onclick="OpenCredentialManager" title="Credential Manager">
                🔑 Credentials
            </button>
        </div>

        @if (!StateService.ValidationResult.IsValid)
        {
            <div class="validation-panel">
                <div class="validation-header" @onclick="ToggleValidationPanel">
                    <span class="validation-icon">⚠️</span>
                    <span>@StateService.ValidationResult.Errors.Count validation error(s)</span>
                    <span class="validation-toggle">@(_isValidationPanelExpanded ? "▼" : "▶")</span>
                </div>
                @if (_isValidationPanelExpanded)
                {
                    <div class="validation-errors">
                        @foreach (var error in StateService.ValidationResult.Errors)
                        {
                            <div class="validation-error">
                                <span class="error-path">@error.Path</span>
                                <span class="error-message">@error.Message</span>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        <WorkflowCanvas OnNodeDoubleClick="OpenNodeEditor"/>
    </div>

    <aside class="config-panel @(_isConfigCollapsed ? "collapsed" : "")">
        <div class="panel-toggle" @onclick="ToggleConfig" title="@(_isConfigCollapsed ? "Show Properties" : "Hide Properties")">
            @if (_isConfigCollapsed)
            {
                <span class="toggle-label-vertical">Properties</span>
            }
            <span class="toggle-icon">@(_isConfigCollapsed ? "◀" : "▶")</span>
        </div>
        @if (!_isConfigCollapsed)
        {
            <NodeConfigPanel/>
        }
    </aside>
</div>

@* Plugin Manager Modal *@
<PluginManager IsOpen="@_isPluginManagerOpen" OnClose="ClosePluginManager"/>

@* Credential Manager Modal *@
<CredentialManager IsOpen="@_isCredentialManagerOpen" OnClose="CloseCredentialManager"/>

@* Workflow Browser Modal *@
<WorkflowBrowser IsOpen="@_isWorkflowBrowserOpen"
                 CurrentWorkflowId="@WorkflowId"
                 OnClose="CloseWorkflowBrowser"/>

@* Node Editor Modal *@
<NodeEditorModal IsOpen="@_isNodeEditorOpen"
                 NodeId="@_editingNodeId"
                 OnClose="CloseNodeEditor"
                 OnSave="CloseNodeEditor"/>
