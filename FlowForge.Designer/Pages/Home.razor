@page "/"

<PageTitle>FlowForge - Workflow Automation</PageTitle>

<div class="home-container">
    <h1>Welcome to FlowForge</h1>
    <p class="lead">Build powerful workflow automations with a visual drag-and-drop interface.</p>

    <div class="home-actions">
        <a href="/designer" class="btn-primary">
            <span class="btn-icon">🎨</span>
            <span>Open Designer</span>
        </a>
    </div>

    <div class="features">
        <div class="feature">
            <span class="feature-icon">⚡</span>
            <h3>Trigger-Based</h3>
            <p>Start workflows with webhooks, schedules, or manual triggers.</p>
        </div>
        <div class="feature">
            <span class="feature-icon">🔗</span>
            <h3>Connect Services</h3>
            <p>Integrate with APIs, databases, and external services.</p>
        </div>
        <div class="feature">
            <span class="feature-icon">⑂</span>
            <h3>Logic Control</h3>
            <p>Use conditionals, loops, and merges to control flow.</p>
        </div>
    </div>
</div>
